{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "paths": {
      "@cronguard/shared": ["../../packages/shared/src"],
      "@cronguard/shared/*": ["../../packages/shared/src/*"]
