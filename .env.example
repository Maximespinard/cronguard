# Clerk
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: PEM public key for networkless JWT verification (skip JWKS fetch)
CLERK_JWT_KEY=
# Svix signing secret from Clerk Dashboard → Webhooks
CLERK_WEBHOOK_SIGNING_SECRET=

# Database (Neon Postgres)
DATABASE_URL=
# Direct (non-pooled) connection for migrations only
DATABASE_URL_DIRECT=

# Resend (email alerts)
RESEND_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# App
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
